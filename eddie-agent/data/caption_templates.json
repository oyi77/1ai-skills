  "hook_formulas": {
    "curiosity_gap": {
      "pattern": "Kenapa [X] terjadi/bisa, padahal [Y]? Ini yang jarang orang tau...",
      "example": "Kenapa orang ini penghasilan 20 juta dari TikTok padahal followernya cuma 500? Ini yang jarang orang tau...",
      "best_for": ["tiktok", "instagram"]
    },
    "contrarian": {
      "pattern": "Semua orang percaya [common belief]. Tapi faktanya [surprising truth].",
      "example": "Semua orang percaya CV bagus = dipanggil interview. Tapi faktanya recruiter rata-rata cuma baca 6 detik.",
      "best_for": ["facebook", "instagram"]
    },
    "number_based": {
      "pattern": "[Number] cara/langkah/rahasia [desirable outcome] yang [qualifier]",
      "example": "3 langkah dapat cashback 40% dari belanja sehari-hari — gratis, tanpa modal",
      "best_for": ["tiktok", "instagram", "facebook"]
    },
    "social_proof": {
      "pattern": "[Relatable persona] udah [specific result] pakai [product/method] — sekarang giliran kamu",
      "example": "Ibu RT di Surabaya ini dapat 5 juta per bulan dari rumah pakai sistem ini — sekarang giliran kamu",
      "best_for": ["facebook", "instagram"]
    }
  },
