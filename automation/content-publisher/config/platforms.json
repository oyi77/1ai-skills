{
    "substack": {
        "login": "https://substack.com/sign-in",
        "dashboard": "https://substack.com/dashboard",
        "editor": "https://{subdomain}.substack.com/publish",
        "selectors": {
            "title_input": "textarea[placeholder='Title']",
            "subtitle_input": "textarea[placeholder='Subtitle']",
            "body_editor": ".p-name",
            "publish_btn": "button:contains('Continue')",
            "schedule_options": ".publish-settings"
        }
    },
    "medium": {
        "login": "https://medium.com/m/signin",
        "editor": "https://medium.com/new-story",
        "selectors": {
            "title_input": "h3.graf--title",
            "body_editor": "p.graf--p",
            "publish_btn": "button[data-action='publish-flow']",
            "tags_input": "input[placeholder='Add a tag...']"
        }
    }
}