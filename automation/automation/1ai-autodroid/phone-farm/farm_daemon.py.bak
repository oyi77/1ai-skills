        @app.post("/tasks/batch")
        async def batch_tasks(
            task_type: str,
            serials: list = Body(..., embed=True),
            user=require_auth("operator"),
        ):
            results = {}
            for serial in serials:
                try:
                    result = self.runner.run_now(serial, task_type)
                    results[serial] = result
                except Exception as e:
                    results[serial] = {"success": False, "error": str(e)}
            return {"results": results, "total": len(serials)}

