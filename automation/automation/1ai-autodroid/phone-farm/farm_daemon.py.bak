        @app.get("/health")
        async def health():
            serials = [
                d["serial"] for d in db.get_all_devices(connected_only=True)["items"]
            ]
            states = self.dm.refresh_all(serials)
            return [
                {
                    "serial": s,
                    "battery": st.battery,
                    "screen_on": st.screen_on,
                    "current_app": st.current_app,
                    "connected": st.connected,
                }
                for s, st in states.items()
            ]

        @app.get("/health/ready")
        async def health_ready():
            """Detailed health check - returns detailed status of all subsystems."""
            health_status = {"status": "ready", "checks": {}}

            # Check database
            try:
                db.get_stats()
                health_status["checks"]["database"] = {"status": "ok"}
            except Exception as e:
                health_status["checks"]["database"] = {
                    "status": "error",
                    "message": str(e),
                }
                health_status["status"] = "degraded"

            # Check ADB servers
            try:
                adb_status = self.dm.pool.get_server_status()
                health_status["checks"]["adb_servers"] = {
                    "status": "ok",
                    "servers": adb_status,
                }
            except Exception as e:
                health_status["checks"]["adb_servers"] = {
                    "status": "error",
                    "message": str(e),
                }
                health_status["status"] = "degraded"

            # Check devices
            try:
                devices_result = db.get_all_devices()
                devices = devices_result["items"]
                connected = sum(1 for d in devices if d.get("connected"))
                health_status["checks"]["devices"] = {
                    "status": "ok",
                    "total": devices_result["total"],
                    "connected": connected,
                }
            except Exception as e:
                health_status["checks"]["devices"] = {
                    "status": "error",
                    "message": str(e),
                }
                health_status["status"] = "degraded"

            # Check task queue
            try:
                queue_depth = self.runner.queue_depth()
                health_status["checks"]["task_queue"] = {
                    "status": "ok" if queue_depth < 1000 else "degraded",
                    "depth": queue_depth,
                }
            except Exception as e:
                health_status["checks"]["task_queue"] = {
                    "status": "error",
                    "message": str(e),
                }

            return health_status

        @app.get("/health/live")
        async def health_live():
            """Simple liveness check - always returns 200 if server is running."""
            return {
                "status": "alive",
                "uptime_seconds": int(time.time() - self.start_time),
            }

        # ── Webhook Endpoints ────────────────────────────────────────────────

        # In-memory webhook config (can be extended to file/DB later)
        _webhook_config = {
            "enabled": False,
            "url": None,
            "events": [],
            "secret": None,
        }

        async def _send_webhook(event_type: str, data: dict):
            """Send webhook notification asynchronously."""
            if not _webhook_config.get("enabled") or not _webhook_config.get("url"):
                return

            payload = {
                "event": event_type,
                "timestamp": datetime.now().isoformat(),
                "data": data,
            }

            try:
                import aiohttp

                async with aiohttp.ClientSession() as session:
                    await session.post(
                        _webhook_config["url"],
                        json=payload,
                        headers={"Content-Type": "application/json"},
                    )
            except ImportError:
                # Fallback to requests if aiohttp not available
                try:
                    import requests

                    requests.post(_webhook_config["url"], json=payload, timeout=5)
                except Exception:
                    pass
            except Exception:
                pass

        @app.get("/webhook/config")
        async def get_webhook_config(user=require_auth("admin")):
            """Get webhook configuration."""
            return {
                "enabled": _webhook_config["enabled"],
                "url": _webhook_config["url"],
                "events": _webhook_config["events"],
            }

        @app.post("/webhook/config")
        async def set_webhook_config(
            enabled: bool = None,
            url: str = None,
            events: list = None,
            user=require_auth("admin"),
        ):
            """Configure webhooks."""
            if enabled is not None:
                _webhook_config["enabled"] = enabled
            if url is not None:
                _webhook_config["url"] = url
            if events is not None:
                _webhook_config["events"] = events
            return {"success": True, "config": _webhook_config}

        @app.post("/webhook")
        async def webhook_event(
            event: str,
            serial: str = None,
            message: str = None,
            data: dict = None,
            user=require_auth("operator"),
        ):
            """Manually trigger a webhook event."""
            valid_events = [
                "task_complete",
                "device_connected",
                "device_disconnected",
                "alert",
            ]
            if event not in valid_events:
                return {"error": f"Invalid event. Valid events: {valid_events}"}, 400

            event_data = {
                "event": event,
                "serial": serial,
                "message": message,
                "data": data or {},
            }

            asyncio.create_task(_send_webhook(event, event_data))
            return {"success": True, "event": event}

