        # ── Video Recording ─────────────────────────────────────────────────

        _recording_procs = {}

        @app.post("/device/{serial}/record/start")
        async def start_recording(
            serial: str, duration: int = 60, user=require_auth("operator")
        ):
            import subprocess as sp

            remote_path = f"/sdcard/autodroid_recording_{int(time.time())}.mp4"
            proc = sp.Popen(
                [
                    ADB,
                    "-s",
                    serial,
                    "shell",
                    "screenrecord",
                    "--time-limit",
                    str(min(duration, 180)),
                    remote_path,
                ],
                stdout=sp.DEVNULL,
                stderr=sp.DEVNULL,
            )
            _recording_procs[serial] = {
                "proc": proc,
                "remote_path": remote_path,
                "started_at": time.time(),
            }
            return {
                "success": True,
                "serial": serial,
                "remote_path": remote_path,
                "duration_limit": min(duration, 180),
            }

        @app.post("/device/{serial}/record/stop")
        async def stop_recording(serial: str, user=require_auth("operator")):
            import subprocess as sp

            info = _recording_procs.get(serial)
            if not info:
                return {"success": False, "error": "No active recording"}
            info["proc"].terminate()
            info["proc"].wait(timeout=10)
            del _recording_procs[serial]
            remote_path = info["remote_path"]
            local_dir = "/tmp/autodroid_recordings/"
            os.makedirs(local_dir, exist_ok=True)
            fname = os.path.basename(remote_path)
            local_path = os.path.join(local_dir, fname)
            r = sp.run(
                [ADB, "-s", serial, "pull", remote_path, local_path],
                capture_output=True,
                timeout=30,
            )
            sp.run(
                [ADB, "-s", serial, "shell", "rm", remote_path],
                capture_output=True,
                timeout=5,
            )
            if r.returncode == 0 and os.path.exists(local_path):
                return FileResponse(local_path, media_type="video/mp4", filename=fname)
            return JSONResponse({"error": "Failed to pull recording"}, status_code=500)

