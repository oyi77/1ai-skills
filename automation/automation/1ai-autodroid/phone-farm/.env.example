# ── Phone Farm Configuration ─────────────────────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# ── Authentication ──────────────────────────────────────────────────────
# Required. Secret key for JWT token signing.
PHONEFARM_JWT_SECRET=change_me_to_a_random_string

# Optional. Path to API keys JSON file (default: config/api_keys.json)
# PHONEFARM_API_KEYS_PATH=config/api_keys.json

# ── Server ──────────────────────────────────────────────────────────────
# Optional. Daemon mode: monitor | active | dashboard
PHONEFARM_MODE=dashboard

# Optional. HTTP server port (default: 8889)
# PHONEFARM_PORT=8889

# Optional. Worker thread count (default: 16)
# PHONEFARM_WORKERS=16

# ── Stripe Billing ──────────────────────────────────────────────────────
# Optional. Set these to enable Stripe usage-based billing.
# If not set, billing endpoints return "not configured" gracefully.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Logging ─────────────────────────────────────────────────────────────
# Optional. Log level: DEBUG | INFO | WARNING | ERROR
# PHONEFARM_LOG_LEVEL=INFO

# ── Docker ──────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
