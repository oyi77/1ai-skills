{
  "skillActivation": {
    "strategy": "selective",
    "description": "Selective skill loading with keyword detection",
    "coreSkills": [
      "core/vilona",
      "core/agent-docs",
      "core/joko-orchestrator",
      "core/find-skills",
      "development/writing-plans",
      "skills/skill-detector"
    ],
    "limits": {
      "maxConcurrentSkills": 10,
      "maxConcurrentMCPs": 5,
      "memoryBudgetMB": 500
    },
    "confidence_threshold": 0.7,
    "skillKeywords": {
      "skills/skill-detector": {
        "keywords": ["detect", "skill", "load", "activate"],
        "priority": "high",
        "alwaysActive": true
      },
      "task-manager": {
        "keywords": ["task", "buat", "kerjakan", "do", "assign", "delegate", "tugas"],
        "priority": "high"
      },
      "content-generator": {
        "keywords": ["konten", "tiktok", "generate", "posting", "content", "video", "ads", "iklan"],
        "priority": "high"
      },
      "trading": {
        "keywords": ["trading", "buy", "sell", "posisi", "entry", "exit", "forex", "crypto", "eurusd", "gold"],
        "priority": "high"
      },
      "search": {
        "keywords": ["search", "find", "cari", "lookup", "explore"],
        "priority": "medium"
      }
    }
  },
  "mcpLoading": {
    "strategy": "lazy",
    "connectionPooling": true,
    "idleTimeoutMinutes": 5,
    "maxConcurrentConnections": 5
  }
}
