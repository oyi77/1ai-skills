# =============================================================================
# OPENCLAW BOT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Environment (development | staging | production)
NODE_ENV=development

# Application
APP_NAME=OpenClaw Bot
APP_VERSION=3.0.0
APP_PORT=3000
APP_URL=https://api.openclaw.ai

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username
BOT_WEBHOOK_SECRET=your_webhook_secret_here
BOT_WEBHOOK_URL=https://your-domain.com/webhook

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (Primary)
DATABASE_URL=postgresql://username:password@localhost:5432/openclaw
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50
DATABASE_TIMEOUT=30000

# PostgreSQL (Read Replica - optional)
DATABASE_REPLICA_URL=postgresql://username:password@replica-host:5432/openclaw

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Redis Cluster (Production)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=redis-node-1:6379,redis-node-2:6379,redis-node-3:6379

# =============================================================================
# AI API CONFIGURATION
# =============================================================================

# GeminiGen.ai (Primary)
GEMINIGEN_API_KEY=your_gemini_api_key
GEMINIGEN_BASE_URL=https://api.geminigen.ai/v1
GEMINIGEN_TIMEOUT=60000

# Fallback AI Providers
KLING_API_KEY=your_kling_api_key
KLING_BASE_URL=https://api.klingai.com

RUNWAY_API_KEY=your_runway_api_key
RUNWAY_BASE_URL=https://api.runwayml.com

# AI Circuit Breaker
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_TIMEOUT=60000

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================

# Primary Gateway: Midtrans
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_MERCHANT_ID=your_merchant_id
MIDTRANS_ENVIRONMENT=sandbox  # sandbox | production
MIDTRANS_SNAP_MODE=true

# Backup Gateway: Tripay
TRIPAY_API_KEY=your_tripay_api_key
TRIPAY_PRIVATE_KEY=your_tripay_private_key
TRIPAY_MERCHANT_CODE=your_merchant_code
TRIPAY_ENVIRONMENT=sandbox  # sandbox | production

# Payment Settings
PAYMENT_TIMEOUT_MINUTES=30
PAYMENT_RETRY_ATTEMPTS=3
PAYMENT_CIRCUIT_BREAKER_THRESHOLD=10

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=openclaw-assets
AWS_S3_INPUT_PREFIX=input/
AWS_S3_OUTPUT_PREFIX=output/
AWS_S3_TEMP_PREFIX=temp/

# Cloudflare R2 (Alternative)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=openclaw-assets

# CDN
CDN_BASE_URL=https://cdn.openclaw.ai
CDN_SIGNED_URL_EXPIRY=86400  # 24 hours in seconds

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================

# BullMQ
QUEUE_PREFIX=openclaw
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF=5000
QUEUE_VIDEO_TIMEOUT=600000  # 10 minutes
QUEUE_PAYMENT_TIMEOUT=120000  # 2 minutes

# Worker Scaling
WORKER_CONCURRENCY=5
WORKER_MAX_JOBS=100

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=86400  # 24 hours

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=30

# Admin Access
ADMIN_TELEGRAM_IDS=123456789,987654321
ADMIN_IP_WHITELIST=127.0.0.1,10.0.0.0/8

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Sentry
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=info  # error | warn | info | debug
LOG_FORMAT=json  # json | pretty
LOG_OUTPUT=console  # console | file | both

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
TELEGRAM_ALERT_BOT_TOKEN=your_alert_bot_token
TELEGRAM_ALERT_CHAT_ID=your_alert_chat_id

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Core Features
FEATURE_MULTI_ANGLE=true
FEATURE_VOICE_CLONING=true
FEATURE_TEAM_WORKSPACE=false
FEATURE_TEMPLATE_MARKETPLACE=false
FEATURE_API_ACCESS=false

# Payment Features
FEATURE_SUBSCRIPTION=true
FEATURE_REFERRAL=true
FEATURE_AFFILIATE_TIER2=true

# AI Features
FEATURE_AUTO_DETECT_NICHE=true
FEATURE_COMPETITOR_ANALYSIS=false
FEATURE_TRENDING_AUDIO=false

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================

# Credit Economy
CREDIT_VIDEO_15S=0.5
CREDIT_VIDEO_30S=1.0
CREDIT_VIDEO_60S=2.0
CREDIT_VIDEO_120S=4.0
CREDIT_IMAGE=0.1
CREDIT_VOICE_CLONE=0.5

# Referral Commission
REFERRAL_TIER1_COMMISSION=0.10
REFERRAL_TIER2_COMMISSION=0.05
REFERRAL_MIN_WITHDRAWAL=50000

# Subscription Prices (IDR)
SUBSCRIPTION_LITE_PRICE=99000
SUBSCRIPTION_PRO_PRICE=199000
SUBSCRIPTION_AGENCY_PRICE=499000

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# OpenClaw Core API
OPENCLAW_CORE_URL=https://core.openclaw.ai
OPENCLAW_CORE_API_KEY=your_core_api_key

# Social Media APIs (for direct publish)
TIKTOK_CLIENT_KEY=your_tiktok_key
TIKTOK_CLIENT_SECRET=your_tiktok_secret

INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Debug
DEBUG=openclaw:*
DEBUG_COLORS=true

# Testing
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/openclaw_test
TEST_REDIS_URL=redis://localhost:6379/1

# Mock Services (for testing)
MOCK_PAYMENT_GATEWAY=false
MOCK_AI_GENERATION=false

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. NEVER commit .env file to version control
# 2. Use strong, unique passwords for production
# 3. Rotate API keys regularly
# 4. Use different credentials for each environment
# 5. Enable 2FA for all service accounts
#
# =============================================================================
