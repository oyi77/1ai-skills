{
  "name": "auto-clipper",
  "version": "1.0.0",
  "description": "AI-powered video clipper - Convert long videos into viral Shorts/TikToks/Reels automatically",
  "skill_id": "auto-clipper",
  "author": "BerkahKarya",
  "category": "content",
  "keywords": ["video", "clipper", "shorts", "tiktok", "reels", "ai", "automation"],
  "platform": "all",
  "permissions": ["file_read", "file_write", "execute"],
  "configuration": {
    "clip_duration": {
      "type": "integer",
      "default": 30,
      "description": "Duration of eachclip in seconds"
    },
    "output_resolution": {
      "type": "string",
      "default": "720p",
      "description": "Output video resolution (480p, 720p, 1080p)"
    },
    "whisper_model": {
      "type": "string",
      "default": "base",
      "description": "Whisper model size (tiny, base, small, medium)"
    },
    "num_clips": {
      "type": "integer",
      "default": 10,
      "description": "Number of golden moments to detect"
    },
    "add_subtitles": {
      "type": "boolean",
      "default": true,
      "description": "Auto-generate and burn subtitles"
    },
    "output_format": {
      "type": "string",
      "default": "mp4",
      "description": "Output video format"
    }
  }
}