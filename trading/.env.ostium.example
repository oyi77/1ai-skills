# Ostium Configuration
# Copy this to .env and fill in your credentials

# Ostium Private Key (EVM wallet private key)
# Get this from MetaMask or your Ethereum wallet
# WARNING: Never commit this to git or share publicly!
OSTIUM_PRIVATE_KEY=your_private_key_here

# Ostium RPC URL
# Get a free RPC URL from Alchemy: https://www.alchemy.com/
# For testnet: Create an Arbitrum Sepolia app
# For mainnet: Create an Arbitrum One app
OSTIUM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/your_api_key_here

# Optional: Set to false for mainnet, true for testnet
# Default: true (testnet)
OSTIUM_TESTNET=true
