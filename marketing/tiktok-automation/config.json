{
  "credentials": {
    "username": "",
    "password": "",
    "sessionFile": "tiktok-session.json",
    "twoFactorSecret": null
  },
  "upload": {
    "defaultPrivacy": "public",
    "allowComments": true,
    "allowDuet": true,
    "allowStitch": true,
    "defaultTags": ["#berkahkarya", "#fyp"],
    "maxVideosPerHour": 10
  },
  "browser": {
    "headless": false,
    "timeout": 30000,
    "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "viewport": {
      "width": 1920,
      "height": 1080
    }
  },
  "selectors": {
    "learningMode": true,
    "minConfidence": 0.8,
    "maxRetries": 3
  },
  "logging": {
    "level": "info",
    "file": "tiktok-automation.log",
    "console": true
  }
}
