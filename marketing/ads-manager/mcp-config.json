{
    "skill": "ads-manager",
    "version": "1.0.0",
    "mcpServers": [
        {
            "name": "ads-mcp",
            "type": "remote",
            "url": "https://ads-mcp.up.railway.app/mcp",
            "transport": "http",
            "platforms": [
                "google-ads",
                "tiktok"
            ],
            "capabilities": [
                "campaign-planning",
                "ad-research",
                "cross-platform-creation",
                "performance-analysis"
            ],
            "requiredEnv": [
                "GOOGLE_ADS_API_KEY",
                "TIKTOK_API_KEY"
            ],
            "priority": "high"
        },
        {
            "name": "quanti-connectors",
            "type": "remote",
            "url": "https://ai.quanti.io/mcp",
            "transport": "http",
            "platforms": [
                "google-ads",
                "meta-ads",
                "tiktok",
                "google-analytics"
            ],
            "capabilities": [
                "unified-analytics",
                "cross-platform-data",
                "roi-tracking",
                "performance-dashboards"
            ],
            "requiredEnv": [
                "QUANTI_API_KEY"
            ],
            "priority": "high"
        },
        {
            "name": "adspirer",
            "type": "third-party",
            "platform": "adspirer.com",
            "capabilities": [
                "ai-insights",
                "creative-optimization",
                "performance-recommendations"
            ],
            "priority": "medium"
        },
        {
            "name": "cdata-linkedin-ads",
            "type": "connector",
            "platform": "linkedin",
            "capabilities": [
                "read-ads-data",
                "campaign-analysis",
                "b2b-research"
            ],
            "requiredEnv": [
                "LINKEDIN_ADS_API_KEY"
            ],
            "priority": "medium"
        },
        {
            "name": "cdata-bing-ads",
            "type": "connector",
            "platform": "bing",
            "capabilities": [
                "read-ads-data",
                "campaign-analysis",
                "search-insights"
            ],
            "requiredEnv": [
                "BING_ADS_API_KEY"
            ],
            "priority": "low"
        }
    ],
    "configuration": {
        "defaultPlatforms": [
            "google-ads",
            "meta-ads",
            "tiktok"
        ],
        "researchTimeRange": "90d",
        "maxCompetitors": 10,
        "adVariationsPerConcept": 10,
        "reportingCadence": "weekly"
    },
    "installation": {
        "steps": [
            "Configure MCP servers in ~/.config/mcp/config.json",
            "Set required environment variables",
            "Verify MCP connectivity",
            "Test API access for each platform"
        ],
        "verification": {
            "ads-mcp": "curl https://ads-mcp.up.railway.app/mcp/health",
            "quanti": "curl https://ai.quanti.io/mcp/health"
        }
    }
}